{
  "name": "@liveboard/shared",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bilibili": {
      "types": "./dist/bilibili.d.ts",
      "default": "./dist/bilibili.js"
    },
    "./resource-name": {
      "types": "./dist/resource-name.d.ts",
      "default": "./dist/resource-name.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
