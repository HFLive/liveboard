NODE_ENV=production

API_PORT=4000
API_PUBLIC_URL=/api
NEXT_PUBLIC_API_URL=/api
WEB_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://liveboard:replace-with-a-strong-password@postgres:5432/liveboard?schema=public
POSTGRES_DB=liveboard
POSTGRES_USER=liveboard
POSTGRES_PASSWORD=replace-with-a-strong-password
REDIS_URL=redis://redis:6379

SESSION_SECRET=replace-with-a-long-random-secret

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=liveboard
MINIO_ROOT_PASSWORD=replace-with-a-strong-password
MINIO_BUCKET=liveboard-assets

NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS=false
